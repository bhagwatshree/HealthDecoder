# Backend Server Port
PORT=3000

# PostgreSQL Connection Credentials (for local development)
PGHOST=localhost
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=medical_db
PGPORT=5432

# Neon PostgreSQL connection string (for AWS Lambda deployment).
# If set, this takes priority over the individual PG* variables above.
# Get yours from https://neon.tech (free tier, no credit card).
# DATABASE_URL=postgres://username:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Gemini API Key (Generate one at Google AI Studio). Kept for backward compatibility —
# used as a single-key fallback if GEMINI_API_KEYS below isn't set.
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Pool of Gemini API keys for the free tier, comma-separated. Each key should be its own
# Google Cloud project (its own free-tier quota). Every logged-in free user is deterministically
# assigned to ONE key in this pool (see backend/keyPool.js), so adding more keys here directly
# raises how many free users the app can support without them competing for the same quota.
# Example: GEMINI_API_KEYS=key_for_project_1,key_for_project_2,key_for_project_3
GEMINI_API_KEYS=YOUR_GEMINI_API_KEY_HERE

# Sarvam AI API Key (Generate one at Sarvam AI Dashboard)
SARVAM_API_KEY=YOUR_SARVAM_API_KEY_HERE

# --- Auth / per-user free tier ---
# Secret used to sign login sessions (JWTs). Set a long random string in production.
JWT_SECRET=change-me-to-a-long-random-string

# Secret used to encrypt users' own API keys at rest (AES-256-GCM). Falls back to
# JWT_SECRET if unset — set a separate value in production.
ENCRYPTION_KEY=change-me-to-a-different-long-random-string

# How many free AI "issuances" (roughly: app sessions/days of scanning) each free-tier
# user gets per day before being asked to add their own key. See backend/keyPool.js.
FREE_TIER_DAILY_LIMIT=50

# --- Phone (MSISDN) OTP login/signup, via Firebase Phone Auth ---
# Firebase Console > Project Settings > Service Accounts > Generate new private key.
# Paste the entire downloaded JSON file's contents here as ONE LINE (no line breaks).
# Leave blank to disable phone-OTP auth — email/password signup and login keep working.
FIREBASE_SERVICE_ACCOUNT_JSON=
