## Copy this file to local.properties (gitignored) and fill in real values.
# sdk.dir is normally written automatically by Android Studio.
sdk.dir=/path/to/Android/Sdk

# API keys used by BuildKeys.kt (read into BuildConfig at build time).
GEMINI_API_KEY=your_gemini_api_key_here
SARVAM_API_KEY=your_sarvam_api_key_here

# OAuth "Web application" client ID from Google Cloud Console (APIs & Services > Credentials).
# Required for the native "Sign in with Google" button on the login screen (Credential Manager
# needs a *server* client ID even though this is an Android app). Use the same client ID as
# the backend's GOOGLE_CLIENT_ID (backend/.env.example). Leave blank to hide that button.
GOOGLE_WEB_CLIENT_ID=your_google_oauth_web_client_id_here
